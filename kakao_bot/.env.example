# 나라배움터 로그인
NARAEBAEUM_ID=your_id
NARAEBAEUM_PW=your_password
NARAEBAEUM_NOTICE_URL=https://e-learning.nhi.go.kr/study/announce/setAnnounceList.do
NARAEBAEUM_MATERIAL_URL=

# 카카오 알림톡 (CoolSMS)
COOLSMS_API_KEY=your_coolsms_api_key
COOLSMS_API_SECRET=your_coolsms_api_secret
KAKAO_SENDER_KEY=your_kakao_channel_sender_key   # 카카오 채널 발신프로필키
KAKAO_TEMPLATE_CODE=your_template_code           # 승인된 알림톡 템플릿 코드
RECIPIENT_PHONE=01012345678                      # 수신자 전화번호 (하이픈 없이)
SENDER_PHONE=01012345678                         # 발신자 전화번호
